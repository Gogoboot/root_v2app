{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ROOT Desktop",
  "version": "0.1.0",
  "identifier": "com.root.app",
"build": {
  "frontendDist": "../src",
  "devUrl": "http://localhost:1420",
  "beforeDevCommand": "npx serve ../src -p 1420",
  "beforeBuildCommand": ""
},
  "app": {
    "windows": [
      {
        "title": "ROOT v2.0 — Desktop",
        "width": 1024,
        "height": 768,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
       "icons/icon.ico"
    ]
  }
}
